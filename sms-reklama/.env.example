# ============================================================
# SMS-REKLAMA — mustaqil tizim (asosiy loyihaga aloqasi yo'q)
# ============================================================

# --- Telegram (gramJS) ---
TG_API_ID=20330024
TG_API_HASH=09f429bbd6278fc534798fb349239e0e

# --- Ma'lumotlar bazasi (ALOHIDA baza!) ---
DATABASE_URL=postgresql://sms_user:PAROL@localhost:5432/sms_reklama

# --- Web panel ---
PORT=4010
ADMIN_PASSWORD=admin123

# --- Monitoring sozlamalari ---
# Har necha soniyada guruhlarni tekshirish
POLL_INTERVAL_SEC=25
# Har guruhdan necha xabar olish
MSG_PER_GROUP=15
# true = faqat yuk (cargo) xabarlaridagi raqamlar; false = barcha raqamlar
ONLY_CARGO=false
# Maksimal session soni
MAX_SESSIONS=20

# --- SMS provider (SemySMS) ---
SMS_PROVIDER=semysms
SEMYSMS_TOKEN=
SEMYSMS_DEVICE=active

# --- SMS yuborish sozlamalari ---
# Avtomatik yuborilsinmi (true) yoki faqat qo'lda (false)
SMS_AUTO_SEND=false
# Soatiga maksimal SMS (flood/ban oldini olish)
SMS_PER_HOUR=200
# 2 SMS orasidagi pauza (soniya)
SMS_DELAY_SEC=8
# Reklama matni (web paneldan ham o'zgartiriladi)
REKLAMA_TEXT=Assalomu alaykum! Yangi yuklar uchun ...
